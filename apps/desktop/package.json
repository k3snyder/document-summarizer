{
  "name": "document-summarizer-desktop",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "lint": "eslint src --max-warnings=0",
    "test": "node --test --experimental-strip-types src/*.test.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri:dev": "tauri dev",
    "prepare:cli-resource": "bash scripts/prepare-cli-resource.sh",
    "tauri:build": "npm run prepare:cli-resource && tauri build",
    "tauri:build:windows": "tauri build --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "^2.9.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.61.0",
    "vite": "^7.2.7"
  }
}
